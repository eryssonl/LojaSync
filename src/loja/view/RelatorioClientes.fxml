<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="loja.controller.RelatorioClientesController"
            fitToWidth="true"
            style="-fx-background-color: transparent;">

    <content>
        <VBox spacing="25"
              alignment="TOP_CENTER"
              styleClass="content-panel">

            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <!-- CABEÇALHO -->
            <VBox spacing="5">
                <Label text="👥 Relatório de Clientes" styleClass="label-title"/>
                <Label text="Analise o comportamento de compra dos clientes" styleClass="label-subtitle"/>
            </VBox>

            <Separator/>

            <!-- FILTROS -->
            <TitledPane text="Filtrar por Período"
                        styleClass="titled-pane-primary"
                        expanded="true">

                <content>
                    <VBox spacing="15">
                        <padding>
                            <Insets top="15" right="15" bottom="15" left="15"/>
                        </padding>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Mês:" styleClass="info-label"/>
                            <ComboBox fx:id="comboMes" prefWidth="70"/>
                            <Label text="Ano:" styleClass="info-label"/>
                            <ComboBox fx:id="comboAno" prefWidth="90"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Gerar Relatório"
                                    onAction="#gerarRelatorio"
                                    styleClass="button-primary"
                                    prefWidth="160"/>
                        </HBox>

                        <!-- BUSCA -->
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <TextField fx:id="campoBusca"
                                       promptText="🔍 Buscar por nome do cliente..."
                                       styleClass="input-field"
                                       prefWidth="250"/>
                            <Region HBox.hgrow="ALWAYS"/>
                        </HBox>

                    </VBox>
                </content>
            </TitledPane>

            <!-- TABELA -->
            <VBox spacing="8">
                <Label text="Clientes" styleClass="label-title" style="-fx-font-size: 16px;"/>
                <TableView fx:id="tabelaClientes" VBox.vgrow="ALWAYS" styleClass="table-view" prefHeight="300">
                    <columns>
                        <TableColumn fx:id="colCliente" text="Cliente" prefWidth="250"/>
                        <TableColumn fx:id="colCompras" text="Compras" prefWidth="100"/>
                        <TableColumn fx:id="colTotal" text="Total Gasto" prefWidth="150"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <!-- TOTAL E STATUS -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label fx:id="lblTotalGeral" text="Total geral: R$ 0,00"
                       styleClass="kpi-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="statusLabel"
                       styleClass="status-label"
                       wrapText="true"/>
            </HBox>

        </VBox>
    </content>
</ScrollPane>
