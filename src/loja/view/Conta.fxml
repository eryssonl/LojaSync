<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="loja.controller.ContaController"
      spacing="15" prefWidth="800" prefHeight="550"
      styleClass="content-panel"
      stylesheets="@estilo.css">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <!-- CABEÇALHO -->
    <VBox spacing="5">
        <Label text="🧾 Detalhe da Conta" styleClass="label-title"/>
        <Label fx:id="labelCliente" text="Conta de: —"
               styleClass="label-subtitle"
               style="-fx-font-size: 16px;"/>
    </VBox>

    <Separator/>

    <!-- KPI: TOTAL -->
    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="kpi-container">
        <Label text="Total a pagar:" styleClass="label-subtitle" style="-fx-font-size: 14px;"/>
        <Label fx:id="labelTotal" text="R$ 0,00"
               styleClass="kpi-value"/>
    </HBox>

    <!-- TABELA DE COMPRAS -->
    <TableView fx:id="tabelaCompras" VBox.vgrow="ALWAYS" styleClass="table-view">
        <columns>
            <TableColumn fx:id="colProduto" text="Produto" prefWidth="200"/>
            <TableColumn fx:id="colQuantidade" text="Qtd" prefWidth="70"/>
            <TableColumn fx:id="colValorTotal" text="Valor" prefWidth="120"/>
            <TableColumn fx:id="colData" text="Data" prefWidth="150"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <!-- AÇÕES -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button text="Fechar Conta"
                onAction="#fecharConta"
                styleClass="button-primary"
                prefWidth="160"/>
    </HBox>

</VBox>
