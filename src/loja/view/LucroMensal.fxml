<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="loja.controller.LucroMensalController"
            fitToWidth="true"
            style="-fx-background-color: transparent;">

    <content>
        <VBox spacing="25"
              alignment="TOP_CENTER"
              styleClass="content-panel">

            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <!-- HEADER -->
            <VBox spacing="5">
                <Label text="💰 Lucro Mensal" styleClass="label-title"/>
                <Label text="Acompanhe o faturamento por mês" styleClass="label-subtitle"/>
            </VBox>

            <Separator/>

            <!-- KPI DESTAQUE -->
            <HBox spacing="15" alignment="CENTER">
                <VBox alignment="CENTER" spacing="5"
                      styleClass="kpi-container"
                      HBox.hgrow="ALWAYS">
                    <Label text="Faturamento Total"
                           styleClass="label-subtitle"/>
                    <Label fx:id="labelTotalGeral" text="R$ 0,00"
                           styleClass="kpi-value"/>
                </VBox>
            </HBox>

            <!-- GRÁFICO -->
            <VBox spacing="8">
                <Label text="Evolução Mensal" styleClass="label-title" style="-fx-font-size: 16px;"/>
                <BarChart fx:id="barChartLucro"
                          VBox.vgrow="ALWAYS"
                          prefHeight="320"
                          title="Lucro por Mês"
                          legendVisible="false">
                    <xAxis>
                        <CategoryAxis label="Mês/Ano"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Valor (R$)"/>
                    </yAxis>
                </BarChart>
            </VBox>

            <!-- TABELA DE DETALHAMENTO -->
            <VBox spacing="8">
                <Label text="Detalhamento" styleClass="label-title" style="-fx-font-size: 16px;"/>
                <TableView fx:id="tabelaLucro" VBox.vgrow="ALWAYS" styleClass="table-view" prefHeight="200">
                    <columns>
                        <TableColumn fx:id="colMes" text="Mês/Ano" prefWidth="200"/>
                        <TableColumn fx:id="colTotal" text="Lucro Total" prefWidth="200"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <!-- STATUS -->
            <Label fx:id="statusLabel"
                   styleClass="status-label"
                   wrapText="true"/>

        </VBox>
    </content>
</ScrollPane>
