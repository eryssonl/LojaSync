<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="loja.controller.CadastroProdutoController"
            fitToWidth="true"
            style="-fx-background-color: transparent;">

    <content>
        <VBox spacing="25"
              alignment="TOP_CENTER"
              styleClass="content-panel form-panel">

            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <!-- HEADER -->
            <VBox spacing="5">
                <Label text="Cadastro de Produto" styleClass="label-title"/>
                <Label text="Preencha as informações do produto" styleClass="label-subtitle"/>
            </VBox>

            <Separator/>

            <!-- SEÇÕES -->
            <VBox spacing="20" fillWidth="true">

                <!-- INFORMAÇÕES -->
                <TitledPane text="Informações Básicas"
                            styleClass="titled-pane-primary"
                            expanded="true">

                    <content>
                        <VBox spacing="12">
                            <padding>
                                <Insets top="15" right="15" bottom="15" left="15"/>
                            </padding>

                            <Label text="Nome do produto"
                                   styleClass="required-label"/>

                            <TextField fx:id="nomeField"
                                       promptText="Ex: Arroz 5kg"
                                       styleClass="input-field">
                                <tooltip>
                                    <Tooltip text="Nome identificador do produto"/>
                                </tooltip>
                            </TextField>

                        </VBox>
                    </content>
                </TitledPane>

                <!-- PREÇOS -->
                <TitledPane text="Preços e Custos"
                            styleClass="titled-pane-primary"
                            expanded="true">

                    <content>
                        <VBox spacing="15">
                            <padding>
                                <Insets top="15" right="15" bottom="15" left="15"/>
                            </padding>

                            <VBox spacing="5">
                                <Label text="Preço de venda"
                                       styleClass="required-label"/>

                                <TextField fx:id="precoField"
                                           promptText="R$ 0,00"
                                           styleClass="currency-field">
                                    <tooltip>
                                        <Tooltip text="Preço de venda do produto"/>
                                    </tooltip>
                                </TextField>
                            </VBox>

                            <VBox spacing="5">
                                <Label text="Custo do produto"
                                       styleClass="optional-label"/>

                                <TextField fx:id="custoField"
                                           promptText="R$ 0,00"
                                           styleClass="currency-field">
                                    <tooltip>
                                        <Tooltip text="Custo de aquisição/produção"/>
                                    </tooltip>
                                </TextField>
                            </VBox>

                        </VBox>
                    </content>
                </TitledPane>

                <!-- ESTOQUE -->
                <TitledPane text="Controle de Estoque"
                            styleClass="titled-pane-primary"
                            expanded="true">

                    <content>
                        <VBox spacing="12">
                            <padding>
                                <Insets top="15" right="15" bottom="15" left="15"/>
                            </padding>

                            <Label text="Quantidade"
                                   styleClass="required-label"/>

                            <TextField fx:id="quantidadeField"
                                       promptText="Ex: 10"
                                       styleClass="input-field">
                                <tooltip>
                                    <Tooltip text="Quantidade disponível em estoque"/>
                                </tooltip>
                            </TextField>

                        </VBox>
                    </content>
                </TitledPane>

            </VBox>

            <!-- BOTÕES -->
            <HBox alignment="CENTER_RIGHT" spacing="10">

                <Button text="Limpar"
                        onAction="#limparCampos"
                        styleClass="button-secondary"
                        prefWidth="110"/>

                <Button text="Cadastrar"
                        onAction="#cadastrarProduto"
                        styleClass="button-primary"
                        prefWidth="140"/>

            </HBox>

            <!-- STATUS -->
            <Label fx:id="statusLabel"
                   styleClass="status-label"
                   wrapText="true"/>

        </VBox>
    </content>
</ScrollPane>
