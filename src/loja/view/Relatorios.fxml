<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="loja.controller.RelatoriosController"
            fitToWidth="true"
            style="-fx-background-color: transparent;">

    <content>
        <VBox spacing="25"
              alignment="TOP_CENTER"
              styleClass="content-panel">

            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <!-- HEADER -->
            <VBox spacing="5">
                <Label text="📊 Relatório Mensal" styleClass="label-title"/>
                <Label text="Selecione o período para visualizar os dados" styleClass="label-subtitle"/>
            </VBox>

            <Separator/>

            <!-- FILTROS -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Mês:" styleClass="info-label"/>
                <ComboBox fx:id="comboMes" prefWidth="70"/>
                <Label text="Ano:" styleClass="info-label"/>
                <ComboBox fx:id="comboAno" prefWidth="90"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Gerar Relatório"
                        onAction="#gerarRelatorio"
                        styleClass="button-primary"
                        prefWidth="160"/>
            </HBox>

            <!-- KPIs -->
            <TilePane hgap="15" vgap="15" prefColumns="3" alignment="CENTER">
                <padding>
                    <Insets top="5"/>
                </padding>

                <VBox alignment="CENTER" spacing="8"
                      styleClass="kpi-container"
                      prefWidth="200">
                    <Label text="🧾" style="-fx-font-size: 24px;"/>
                    <Label text="Total de Vendas"
                           styleClass="label-subtitle"
                           style="-fx-font-size: 12px;"/>
                    <Label fx:id="kpiQtdVendas" text="0"
                           styleClass="kpi-value"/>
                </VBox>

                <VBox alignment="CENTER" spacing="8"
                      styleClass="kpi-container"
                      prefWidth="200">
                    <Label text="💵" style="-fx-font-size: 24px;"/>
                    <Label text="Faturamento"
                           styleClass="label-subtitle"
                           style="-fx-font-size: 12px;"/>
                    <Label fx:id="kpiFaturamento" text="R$ 0,00"
                           styleClass="kpi-value"/>
                </VBox>

                <VBox alignment="CENTER" spacing="8"
                      styleClass="kpi-container"
                      prefWidth="200">
                    <Label text="📈" style="-fx-font-size: 24px;"/>
                    <Label text="Lucro"
                           styleClass="label-subtitle"
                           style="-fx-font-size: 12px;"/>
                    <Label fx:id="kpiLucro" text="R$ 0,00"
                           styleClass="kpi-value"/>
                </VBox>

            </TilePane>

            <!-- GRÁFICO -->
            <VBox spacing="8">
                <Label text="Vendas por Produto" styleClass="label-title" style="-fx-font-size: 16px;"/>
                <BarChart fx:id="barChartVendas"
                          prefHeight="280"
                          title="Quantidade vendida por produto"
                          legendVisible="false">
                    <xAxis>
                        <CategoryAxis label="Produto"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Quantidade"/>
                    </yAxis>
                </BarChart>
            </VBox>

            <!-- TABELA DE DETALHAMENTO -->
            <VBox spacing="8">
                <Label text="Detalhamento das Vendas" styleClass="label-title" style="-fx-font-size: 16px;"/>
                <TableView fx:id="tabelaRelatorio" VBox.vgrow="ALWAYS" styleClass="table-view" prefHeight="220">
                    <columns>
                        <TableColumn fx:id="colProduto" text="Produto" prefWidth="200"/>
                        <TableColumn fx:id="colQuantidade" text="Qtd" prefWidth="80"/>
                        <TableColumn fx:id="colData" text="Data" prefWidth="150"/>
                        <TableColumn fx:id="colTotal" text="Valor Total" prefWidth="140"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <!-- TOTAL E STATUS -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label fx:id="labelTotal" text="Total do mês: R$ 0,00"
                       styleClass="kpi-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="statusLabel"
                       styleClass="status-label"
                       wrapText="true"/>
            </HBox>

        </VBox>
    </content>
</ScrollPane>
