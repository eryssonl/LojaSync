<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="loja.controller.VendasController"
            fitToWidth="true"
            style="-fx-background-color: transparent;">

    <content>
        <VBox spacing="25"
              alignment="TOP_CENTER"
              styleClass="content-panel form-panel">

            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <!-- HEADER -->
            <VBox spacing="5">
                <Label text="🛒 Registrar Venda" styleClass="label-title"/>
                <Label text="Selecione o produto e informe a quantidade" styleClass="label-subtitle"/>
            </VBox>

            <Separator/>

            <!-- SEÇÃO 1: SELEÇÃO DO PRODUTO -->
            <TitledPane text="1. Selecione o Produto"
                        styleClass="titled-pane-primary"
                        expanded="true">

                <content>
                    <VBox spacing="12">
                        <padding>
                            <Insets top="15" right="15" bottom="15" left="15"/>
                        </padding>

                        <TextField fx:id="campoPesquisa"
                                   promptText="🔍 Buscar por nome..."
                                   styleClass="input-field">
                            <tooltip>
                                <Tooltip text="Digite para filtrar os produtos disponíveis"/>
                            </tooltip>
                        </TextField>

                        <TableView fx:id="tabelaProdutos"
                                   VBox.vgrow="ALWAYS"
                                   styleClass="table-view"
                                   prefHeight="220">
                            <columns>
                                <TableColumn fx:id="colNome" text="Produto" prefWidth="200"/>
                                <TableColumn fx:id="colPreco" text="Preço" prefWidth="120"/>
                                <TableColumn fx:id="colQuantidade" text="Estoque" prefWidth="100"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>

                    </VBox>
                </content>
            </TitledPane>

            <!-- SEÇÃO 2: DADOS DA VENDA -->
            <TitledPane text="2. Dados da Venda"
                        styleClass="titled-pane-primary"
                        expanded="true">

                <content>
                    <VBox spacing="15">
                        <padding>
                            <Insets top="15" right="15" bottom="15" left="15"/>
                        </padding>

                        <VBox spacing="5">
                            <Label text="Cliente (opcional)" styleClass="optional-label"/>
                            <TextField fx:id="campoCliente"
                                       promptText="Ex: João Silva"
                                       styleClass="input-field">
                                <tooltip>
                                    <Tooltip text="Se preenchido, a venda será vinculada à conta do cliente"/>
                                </tooltip>
                            </TextField>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Quantidade" styleClass="required-label"/>
                            <TextField fx:id="campoQuantidade"
                                       promptText="Ex: 5"
                                       styleClass="input-field">
                                <tooltip>
                                    <Tooltip text="Quantidade de unidades a vender"/>
                                </tooltip>
                            </TextField>
                        </VBox>

                    </VBox>
                </content>
            </TitledPane>

            <!-- RESUMO DA VENDA -->
            <TitledPane text="Resumo da Venda"
                        styleClass="titled-pane-primary"
                        expanded="true">

                <content>
                    <GridPane hgap="15" vgap="10">
                        <padding>
                            <Insets top="15" right="15" bottom="15" left="15"/>
                        </padding>

                        <columnConstraints>
                            <ColumnConstraints halignment="LEFT" prefWidth="160"/>
                            <ColumnConstraints halignment="RIGHT" prefWidth="140"/>
                        </columnConstraints>

                        <Label text="Produto:"
                               styleClass="info-label"
                               GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label fx:id="resumoProduto" text="—"
                               styleClass="info-value"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Preço unitário:"
                               styleClass="info-label"
                               GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Label fx:id="resumoPreco" text="—"
                               styleClass="info-value"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Estoque disponível:"
                               styleClass="info-label"
                               GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <Label fx:id="resumoEstoque" text="—"
                               styleClass="info-value"
                               GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Separator GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2"/>

                        <Label text="Total da venda:"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: -cor-secondary;"
                               GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <Label fx:id="resumoTotal" text="R$ 0,00"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -cor-secondary;"
                               GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                    </GridPane>
                </content>
            </TitledPane>

            <!-- BOTÕES -->
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button text="Limpar"
                        onAction="#limparCampos"
                        styleClass="button-secondary"
                        prefWidth="110"/>
                <Button text="Registrar Venda"
                        onAction="#registrarVenda"
                        styleClass="button-primary"
                        prefWidth="170"/>
            </HBox>

            <!-- STATUS -->
            <Label fx:id="statusLabel"
                   styleClass="status-label"
                   wrapText="true"/>

        </VBox>
    </content>
</ScrollPane>
