<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="loja.controller.ListagemProdutoController"
      spacing="15" prefHeight="650"
      stylesheets="@estilo.css"
      styleClass="content-panel">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <!-- CABEÇALHO -->
    <VBox spacing="5">
        <Label text="📦 Listagem de Produtos" styleClass="label-title"/>
        <Label text="Gerencie o estoque da sua loja" styleClass="label-subtitle"/>
    </VBox>

    <Separator styleClass="form-separator"/>

    <!-- RESUMO E BUSCA -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label fx:id="labelResumo" text="Total de itens: 0 | Valor total: R$ 0,00"
               styleClass="kpi-label"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="campoBusca"
                   promptText="🔍 Buscar por nome..."
                   styleClass="input-field"
                   prefWidth="250"/>
    </HBox>

    <!-- TABELA -->
    <TableView fx:id="tabelaProdutos" VBox.vgrow="ALWAYS" styleClass="table-view">
        <columns>
            <TableColumn fx:id="colNome" text="Produto" prefWidth="200"/>
            <TableColumn fx:id="colPreco" text="Preço" prefWidth="110"/>
            <TableColumn fx:id="colCusto" text="Custo" prefWidth="110"/>
            <TableColumn fx:id="colQuantidade" text="Estoque" prefWidth="90"/>
            <TableColumn fx:id="colMargem" text="Lucro Unit." prefWidth="110"/>
            <TableColumn fx:id="colMargemPercentual" text="Lucro %" prefWidth="90"/>
            <TableColumn fx:id="colLucro" text="Lucro Total" prefWidth="120"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <!-- AÇÕES -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Adicionar Estoque"
                onAction="#adicionarEstoque"
                styleClass="button-success"
                prefWidth="180"/>
        <Button text="Atualizar Lista"
                onAction="#atualizarTabela"
                styleClass="button-secondary"
                prefWidth="140"/>
        <Button text="Remover Selecionado"
                onAction="#removerProduto"
                styleClass="button-danger"
                prefWidth="180"/>
    </HBox>

    <!-- STATUS -->
    <Label fx:id="statusLabel"
           styleClass="status-label"
           wrapText="true"/>

</VBox>
